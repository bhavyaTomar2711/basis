# Supabase — required for /api/audit, /audit/[id], /a/[slug] (Day 3+).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Anon key not used yet, but worth setting for future client-side reads.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Day 3 — Gemini for /api/summary. Server-side only; never client-exposed.
# GEMINI_API_KEY=

# Day 3 — Resend for /api/lead transactional emails.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=

# Day 3 — Upstash Redis for rate limiting all three API routes.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
